# ==========================================
# 🔐 RECIPE FINDER PRO - ENVIRONMENT VARIABLES
# ==========================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to exactly '.env'
# 2. Replace the dummy values below with your real API keys
# 3. NEVER commit your real '.env' file to Git!
# ==========================================

# --- EDAMAM API (Recipe Search) ---
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_app_key_here
EDAMAM_BASE_URL=https://api.edamam.com/api/recipes/v2

# --- MEALDB API ---
MealDB_BASE_URL=https://www.themealdb.com/api/json/v1/1/search.php

# --- SPOONACULAR API ---
SPOONACULAR_API_KEY=your_spoonacular_api_key_here
SPOONACULAR_BASE_URL=https://api.spoonacular.com/recipes/complexSearch

# --- TASTY API (RapidAPI) ---
TASTY_API_KEY=your_rapidapi_key_here
TASTY_API_HOST=tasty.p.rapidapi.com
TASTY_BASE_URL=https://tasty.p.rapidapi.com/recipes/list

# --- AI & MACHINE LEARNING ---
# 0 = Allow Hugging Face to download the CLIP model (First Run Only)
# 1 = Run in 100% Offline Mode (Use after model is downloaded)
TRANSFORMERS_OFFLINE=0

# --- FLASK SERVER CONFIGURATION ---
PORT=5000
